<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LevelUp.HelpPage"
             Title="Hunter's Guide"
             BackgroundColor="#050510">

    <!-- WCAG 2.4.2: Page Titled -->

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="16" MaximumWidthRequest="700"
                             HorizontalOptions="Center">

            <!-- Header -->
            <Label Text="[ SYSTEM NOTIFICATION ]"
                   TextColor="#3D5AFE" FontSize="12" FontAttributes="Bold"
                   HorizontalTextAlignment="Center"
                   IsInAccessibleTree="False" />

            <!-- WCAG 1.3.1: main heading at level 1 -->
            <Label Text="Hunter's Guide"
                   TextColor="White" FontSize="28" FontAttributes="Bold"
                   HorizontalTextAlignment="Center"
                   FontAutoScalingEnabled="True"
                   SemanticProperties.HeadingLevel="Level1"
                   SemanticProperties.Description="Hunter's Guide — help and instructions" />

            <Label Text="Everything you need to know"
                   TextColor="#9966FF" FontSize="14"
                   HorizontalTextAlignment="Center"
                   FontAutoScalingEnabled="True" />

            <!-- Section: Getting Started -->
            <Border Stroke="#3D5AFE" StrokeThickness="2" Padding="20"
                    BackgroundColor="#0A0A1A" StrokeShape="RoundRectangle 4">
                <VerticalStackLayout Spacing="10">
                    <Label Text="[ GETTING STARTED ]"
                           TextColor="#3D5AFE" FontSize="12" FontAttributes="Bold"
                           SemanticProperties.HeadingLevel="Level2"
                           SemanticProperties.Description="Getting started section" />
                    <BoxView HeightRequest="1" BackgroundColor="#3D5AFE" Margin="0,0,0,4" IsInAccessibleTree="False" />
                    <Label TextColor="#CCCCCC" FontSize="13" LineBreakMode="WordWrap" FontAutoScalingEnabled="True"
                           Text="Welcome, Hunter. LevelUp turns your real-world fitness into a ranking system inspired by Solo Leveling. Complete daily quests and log workouts to earn XP and climb from Rank E all the way to Shadow Monarch." />
                    <Label TextColor="#CCCCCC" FontSize="13" LineBreakMode="WordWrap" FontAutoScalingEnabled="True"
                           Text="Your progress is shown on the main screen — check your rank badge, XP bar, and daily quest status at a glance." />
                    <Label TextColor="#CCCCCC" FontSize="13" LineBreakMode="WordWrap" FontAutoScalingEnabled="True"
                           Text="Step 1: Open the app. Your dashboard shows your current rank and XP." />
                    <Label TextColor="#CCCCCC" FontSize="13" LineBreakMode="WordWrap" FontAutoScalingEnabled="True"
                           Text="Step 2: Complete real-world fitness quests, then tap their COMPLETE button to claim XP." />
                    <Label TextColor="#CCCCCC" FontSize="13" LineBreakMode="WordWrap" FontAutoScalingEnabled="True"
                           Text="Step 3: Open the Workout Log to record specific exercises and earn bonus XP." />
                    <Label TextColor="#CCCCCC" FontSize="13" LineBreakMode="WordWrap" FontAutoScalingEnabled="True"
                           Text="Step 4: Accumulate XP to rank up. Reach Rank S and maintain it daily." />
                </VerticalStackLayout>
            </Border>

            <!-- Section: Daily Quests -->
            <Border Stroke="#3D5AFE" StrokeThickness="2" Padding="20"
                    BackgroundColor="#0A0A1A" StrokeShape="RoundRectangle 4">
                <VerticalStackLayout Spacing="10">
                    <Label Text="[ DAILY QUESTS ]"
                           TextColor="#3D5AFE" FontSize="12" FontAttributes="Bold"
                           SemanticProperties.HeadingLevel="Level2"
                           SemanticProperties.Description="Daily quests section" />
                    <BoxView HeightRequest="1" BackgroundColor="#3D5AFE" Margin="0,0,0,4" IsInAccessibleTree="False" />
                    <Label TextColor="#CCCCCC" FontSize="13" LineBreakMode="WordWrap" FontAutoScalingEnabled="True"
                           Text="Each day you have 4 quests to complete in real life. Once you have physically done a quest, tap its COMPLETE button to claim your reward." />
                    <Label TextColor="#778899" FontSize="13" LineBreakMode="WordWrap" FontAutoScalingEnabled="True"
                           Text="Each completed quest awards +50 XP toward your hunter rank." />

                    <BoxView HeightRequest="1" BackgroundColor="#1A1A2E" Margin="0,4" IsInAccessibleTree="False" />

                    <Grid ColumnDefinitions="24,*" ColumnSpacing="10"
                          SemanticProperties.Description="Quest 1: Walk 10,000 steps. Hit your daily step goal using a pedometer or phone health app.">
                        <Label Grid.Column="0" Text="①" TextColor="#3D5AFE" FontSize="14" FontAttributes="Bold"
                               VerticalTextAlignment="Center" IsInAccessibleTree="False" />
                        <VerticalStackLayout Grid.Column="1" Spacing="2">
                            <Label Text="Walk 10,000 Steps" TextColor="White" FontSize="14" FontAttributes="Bold"
                                   FontAutoScalingEnabled="True" IsInAccessibleTree="False" />
                            <Label Text="Hit your daily step goal — use a pedometer or phone health app to track."
                                   TextColor="#778899" FontSize="12" LineBreakMode="WordWrap"
                                   FontAutoScalingEnabled="True" IsInAccessibleTree="False" />
                        </VerticalStackLayout>
                    </Grid>

                    <Grid ColumnDefinitions="24,*" ColumnSpacing="10"
                          SemanticProperties.Description="Quest 2: Do 50 push-ups. Upper body strength, split into sets as needed.">
                        <Label Grid.Column="0" Text="②" TextColor="#3D5AFE" FontSize="14" FontAttributes="Bold"
                               VerticalTextAlignment="Center" IsInAccessibleTree="False" />
                        <VerticalStackLayout Grid.Column="1" Spacing="2">
                            <Label Text="Do 50 Push-ups" TextColor="White" FontSize="14" FontAttributes="Bold"
                                   FontAutoScalingEnabled="True" IsInAccessibleTree="False" />
                            <Label Text="Upper body strength — split into sets as needed."
                                   TextColor="#778899" FontSize="12" LineBreakMode="WordWrap"
                                   FontAutoScalingEnabled="True" IsInAccessibleTree="False" />
                        </VerticalStackLayout>
                    </Grid>

                    <Grid ColumnDefinitions="24,*" ColumnSpacing="10"
                          SemanticProperties.Description="Quest 3: Do 50 sit-ups. Core strength, keep your form steady.">
                        <Label Grid.Column="0" Text="③" TextColor="#3D5AFE" FontSize="14" FontAttributes="Bold"
                               VerticalTextAlignment="Center" IsInAccessibleTree="False" />
                        <VerticalStackLayout Grid.Column="1" Spacing="2">
                            <Label Text="Do 50 Sit-ups" TextColor="White" FontSize="14" FontAttributes="Bold"
                                   FontAutoScalingEnabled="True" IsInAccessibleTree="False" />
                            <Label Text="Core strength — keep your form steady."
                                   TextColor="#778899" FontSize="12" LineBreakMode="WordWrap"
                                   FontAutoScalingEnabled="True" IsInAccessibleTree="False" />
                        </VerticalStackLayout>
                    </Grid>

                    <Grid ColumnDefinitions="24,*" ColumnSpacing="10"
                          SemanticProperties.Description="Quest 4: Do 100 squats. Lower body strength, go at your own pace.">
                        <Label Grid.Column="0" Text="④" TextColor="#3D5AFE" FontSize="14" FontAttributes="Bold"
                               VerticalTextAlignment="Center" IsInAccessibleTree="False" />
                        <VerticalStackLayout Grid.Column="1" Spacing="2">
                            <Label Text="Do 100 Squats" TextColor="White" FontSize="14" FontAttributes="Bold"
                                   FontAutoScalingEnabled="True" IsInAccessibleTree="False" />
                            <Label Text="Lower body strength — go at your own pace."
                                   TextColor="#778899" FontSize="12" LineBreakMode="WordWrap"
                                   FontAutoScalingEnabled="True" IsInAccessibleTree="False" />
                        </VerticalStackLayout>
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- Section: Workout Log -->
            <Border Stroke="#9966FF" StrokeThickness="2" Padding="20"
                    BackgroundColor="#0A0A1A" StrokeShape="RoundRectangle 4">
                <VerticalStackLayout Spacing="10">
                    <Label Text="[ WORKOUT LOG ]"
                           TextColor="#9966FF" FontSize="12" FontAttributes="Bold"
                           SemanticProperties.HeadingLevel="Level2"
                           SemanticProperties.Description="Workout log section" />
                    <BoxView HeightRequest="1" BackgroundColor="#9966FF" Margin="0,0,0,4" IsInAccessibleTree="False" />
                    <Label TextColor="#CCCCCC" FontSize="13" LineBreakMode="WordWrap" FontAutoScalingEnabled="True"
                           Text="Step 1: Tap 'Open Workout Log' from the main dashboard." />
                    <Label TextColor="#CCCCCC" FontSize="13" LineBreakMode="WordWrap" FontAutoScalingEnabled="True"
                           Text="Step 2: Enter an exercise name, weight in kg, and your rep count. Tap 'Add Exercise'." />
                    <Label TextColor="#CCCCCC" FontSize="13" LineBreakMode="WordWrap" FontAutoScalingEnabled="True"
                           Text="Step 3: Your first exercise of the day automatically completes a bonus quest worth +50 XP." />
                    <Label TextColor="#CCCCCC" FontSize="13" LineBreakMode="WordWrap" FontAutoScalingEnabled="True"
                           Text="Step 4: Tick the checkbox next to an exercise once you have completed that set. It turns green with a strikethrough." />
                    <Label TextColor="#778899" FontSize="12" LineBreakMode="WordWrap" FontAutoScalingEnabled="True"
                           Text="Tip: the stats bar at the top shows exercises logged, completed, and XP earned this session. Your workout history is saved and shown below the list." />
                </VerticalStackLayout>
            </Border>

            <!-- Section: XP & Ranks -->
            <Border Stroke="#3D5AFE" StrokeThickness="2" Padding="20"
                    BackgroundColor="#0A0A1A" StrokeShape="RoundRectangle 4">
                <VerticalStackLayout Spacing="10">
                    <Label Text="[ XP &amp; RANKS ]"
                           TextColor="#3D5AFE" FontSize="12" FontAttributes="Bold"
                           SemanticProperties.HeadingLevel="Level2"
                           SemanticProperties.Description="XP and ranks section" />
                    <BoxView HeightRequest="1" BackgroundColor="#3D5AFE" Margin="0,0,0,4" IsInAccessibleTree="False" />
                    <Label TextColor="#CCCCCC" FontSize="13" LineBreakMode="WordWrap" FontAutoScalingEnabled="True"
                           Text="Every completed quest awards XP. Accumulate enough XP to advance through six hunter ranks. When you rank up, the system announces it with an animation and sound." />

                    <BoxView HeightRequest="1" BackgroundColor="#1A1A2E" Margin="0,4" IsInAccessibleTree="False" />

                    <Grid ColumnDefinitions="32,110,*" ColumnSpacing="8">
                        <Label Grid.Column="0" Text="Rank" TextColor="#778899" FontSize="12" FontAttributes="Bold" />
                        <Label Grid.Column="1" Text="XP Required" TextColor="#778899" FontSize="12" FontAttributes="Bold" />
                        <Label Grid.Column="2" Text="Title" TextColor="#778899" FontSize="12" FontAttributes="Bold" />
                    </Grid>
                    <BoxView HeightRequest="1" BackgroundColor="#3D5AFE" IsInAccessibleTree="False" />

                    <Grid ColumnDefinitions="32,110,*" ColumnSpacing="8" SemanticProperties.Description="Rank E, 0 to 199 XP, Iron Hunter">
                        <Label Grid.Column="0" Text="E" TextColor="#778899" FontSize="13" FontAttributes="Bold" IsInAccessibleTree="False" />
                        <Label Grid.Column="1" Text="0 – 199" TextColor="White" FontSize="13" IsInAccessibleTree="False" />
                        <Label Grid.Column="2" Text="Iron Hunter" TextColor="White" FontSize="13" IsInAccessibleTree="False" />
                    </Grid>
                    <Grid ColumnDefinitions="32,110,*" ColumnSpacing="8" SemanticProperties.Description="Rank D, 200 to 399 XP, Bronze Hunter">
                        <Label Grid.Column="0" Text="D" TextColor="#5588BB" FontSize="13" FontAttributes="Bold" IsInAccessibleTree="False" />
                        <Label Grid.Column="1" Text="200 – 399" TextColor="White" FontSize="13" IsInAccessibleTree="False" />
                        <Label Grid.Column="2" Text="Bronze Hunter" TextColor="White" FontSize="13" IsInAccessibleTree="False" />
                    </Grid>
                    <Grid ColumnDefinitions="32,110,*" ColumnSpacing="8" SemanticProperties.Description="Rank C, 400 to 699 XP, Silver Hunter">
                        <Label Grid.Column="0" Text="C" TextColor="#3D5AFE" FontSize="13" FontAttributes="Bold" IsInAccessibleTree="False" />
                        <Label Grid.Column="1" Text="400 – 699" TextColor="White" FontSize="13" IsInAccessibleTree="False" />
                        <Label Grid.Column="2" Text="Silver Hunter" TextColor="White" FontSize="13" IsInAccessibleTree="False" />
                    </Grid>
                    <Grid ColumnDefinitions="32,110,*" ColumnSpacing="8" SemanticProperties.Description="Rank B, 700 to 999 XP, Gold Hunter">
                        <Label Grid.Column="0" Text="B" TextColor="#7B61FF" FontSize="13" FontAttributes="Bold" IsInAccessibleTree="False" />
                        <Label Grid.Column="1" Text="700 – 999" TextColor="White" FontSize="13" IsInAccessibleTree="False" />
                        <Label Grid.Column="2" Text="Gold Hunter" TextColor="White" FontSize="13" IsInAccessibleTree="False" />
                    </Grid>
                    <Grid ColumnDefinitions="32,110,*" ColumnSpacing="8" SemanticProperties.Description="Rank A, 1000 to 1499 XP, Platinum Hunter">
                        <Label Grid.Column="0" Text="A" TextColor="#9966FF" FontSize="13" FontAttributes="Bold" IsInAccessibleTree="False" />
                        <Label Grid.Column="1" Text="1000 – 1499" TextColor="White" FontSize="13" IsInAccessibleTree="False" />
                        <Label Grid.Column="2" Text="Platinum Hunter" TextColor="White" FontSize="13" IsInAccessibleTree="False" />
                    </Grid>
                    <Grid ColumnDefinitions="32,110,*" ColumnSpacing="8" SemanticProperties.Description="Rank S, 1500 or more XP, Shadow Monarch">
                        <Label Grid.Column="0" Text="S" TextColor="#FFD700" FontSize="13" FontAttributes="Bold" IsInAccessibleTree="False" />
                        <Label Grid.Column="1" Text="1500+" TextColor="White" FontSize="13" IsInAccessibleTree="False" />
                        <Label Grid.Column="2" Text="Shadow Monarch" TextColor="White" FontSize="13" IsInAccessibleTree="False" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- Section: S Rank Maintenance -->
            <Border Stroke="#FFD700" StrokeThickness="2" Padding="20"
                    BackgroundColor="#0A0A1A" StrokeShape="RoundRectangle 4">
                <VerticalStackLayout Spacing="10">
                    <Label Text="[ S RANK MAINTENANCE ]"
                           TextColor="#FFD700" FontSize="12" FontAttributes="Bold"
                           SemanticProperties.HeadingLevel="Level2"
                           SemanticProperties.Description="S Rank maintenance section" />
                    <BoxView HeightRequest="1" BackgroundColor="#FFD700" Margin="0,0,0,4" IsInAccessibleTree="False" />
                    <Label TextColor="#CCCCCC" FontSize="13" LineBreakMode="WordWrap" FontAutoScalingEnabled="True"
                           Text="Reaching Rank S makes you Shadow Monarch — but the title must be maintained. You are required to complete at least 2 daily quests every day to keep your rank." />
                    <Label TextColor="#FF4444" FontSize="13" FontAttributes="Bold" LineBreakMode="WordWrap" FontAutoScalingEnabled="True"
                           Text="Warning: if maintenance fails, your rank drops back to Rank A: Platinum Hunter and you must climb again."
                           SemanticProperties.Description="Warning: if maintenance fails, your rank drops back to Rank A Platinum Hunter and you must climb again." />
                    <Label TextColor="#778899" FontSize="12" LineBreakMode="WordWrap" FontAutoScalingEnabled="True"
                           Text="Use the Simulate Rank Decay button (visible only at Rank S) to test this mechanic without waiting." />
                </VerticalStackLayout>
            </Border>

            <!-- Section: Tips -->
            <Border Stroke="#3D5AFE" StrokeThickness="2" Padding="20"
                    BackgroundColor="#0A0A1A" StrokeShape="RoundRectangle 4">
                <VerticalStackLayout Spacing="10">
                    <Label Text="[ HUNTER TIPS ]"
                           TextColor="#3D5AFE" FontSize="12" FontAttributes="Bold"
                           SemanticProperties.HeadingLevel="Level2"
                           SemanticProperties.Description="Hunter tips section" />
                    <BoxView HeightRequest="1" BackgroundColor="#3D5AFE" Margin="0,0,0,4" IsInAccessibleTree="False" />

                    <Grid ColumnDefinitions="20,*" ColumnSpacing="8">
                        <Label Grid.Column="0" Text="▸" TextColor="#9966FF" FontSize="14"
                               VerticalTextAlignment="Start" IsInAccessibleTree="False" />
                        <Label Grid.Column="1" TextColor="#CCCCCC" FontSize="13" LineBreakMode="WordWrap" FontAutoScalingEnabled="True"
                               Text="Do your quests every day — consistency is how you reach Rank S." />
                    </Grid>
                    <Grid ColumnDefinitions="20,*" ColumnSpacing="8">
                        <Label Grid.Column="0" Text="▸" TextColor="#9966FF" FontSize="14"
                               VerticalTextAlignment="Start" IsInAccessibleTree="False" />
                        <Label Grid.Column="1" TextColor="#CCCCCC" FontSize="13" LineBreakMode="WordWrap" FontAutoScalingEnabled="True"
                               Text="Log at least one exercise each day in the Workout Log to earn your bonus quest XP." />
                    </Grid>
                    <Grid ColumnDefinitions="20,*" ColumnSpacing="8">
                        <Label Grid.Column="0" Text="▸" TextColor="#9966FF" FontSize="14"
                               VerticalTextAlignment="Start" IsInAccessibleTree="False" />
                        <Label Grid.Column="1" TextColor="#CCCCCC" FontSize="13" LineBreakMode="WordWrap" FontAutoScalingEnabled="True"
                               Text="Turn off Voice Announcements using the toggle on the dashboard if you are in a public place." />
                    </Grid>
                    <Grid ColumnDefinitions="20,*" ColumnSpacing="8">
                        <Label Grid.Column="0" Text="▸" TextColor="#9966FF" FontSize="14"
                               VerticalTextAlignment="Start" IsInAccessibleTree="False" />
                        <Label Grid.Column="1" TextColor="#CCCCCC" FontSize="13" LineBreakMode="WordWrap" FontAutoScalingEnabled="True"
                               Text="Shake your device at any time to receive a motivational system message." />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- Section: Accessibility — WCAG 2.1 Reference -->
            <Border Stroke="#3D5AFE" StrokeThickness="2" Padding="20"
                    BackgroundColor="#0A0A1A" StrokeShape="RoundRectangle 4">
                <VerticalStackLayout Spacing="10">
                    <Label Text="[ ACCESSIBILITY ]"
                           TextColor="#3D5AFE" FontSize="12" FontAttributes="Bold"
                           SemanticProperties.HeadingLevel="Level2"
                           SemanticProperties.Description="Accessibility information section" />
                    <BoxView HeightRequest="1" BackgroundColor="#3D5AFE" Margin="0,0,0,4" IsInAccessibleTree="False" />
                    <Label TextColor="#CCCCCC" FontSize="13" LineBreakMode="WordWrap" FontAutoScalingEnabled="True"
                           Text="LevelUp is designed with accessibility in mind, following the Web Content Accessibility Guidelines (WCAG) 2.1 for mobile applications." />

                    <Label TextColor="#9966FF" FontSize="13" FontAttributes="Bold" FontAutoScalingEnabled="True"
                           Text="Guidelines applied:" />

                    <Label TextColor="#CCCCCC" FontSize="13" LineBreakMode="WordWrap" FontAutoScalingEnabled="True"
                           Text="1.1.1 Non-text Content — all interactive elements and icons have screen reader descriptions via SemanticProperties." />
                    <Label TextColor="#CCCCCC" FontSize="13" LineBreakMode="WordWrap" FontAutoScalingEnabled="True"
                           Text="1.3.1 Info and Relationships — page sections are marked with heading levels (Level 1, Level 2) for screen reader navigation." />
                    <Label TextColor="#CCCCCC" FontSize="13" LineBreakMode="WordWrap" FontAutoScalingEnabled="True"
                           Text="1.4.3 Contrast — white and light text on dark backgrounds meets the 4.5:1 minimum contrast ratio." />
                    <Label TextColor="#CCCCCC" FontSize="13" LineBreakMode="WordWrap" FontAutoScalingEnabled="True"
                           Text="1.4.4 Resize Text — FontAutoScalingEnabled is applied throughout, respecting the user's system font size preference." />
                    <Label TextColor="#CCCCCC" FontSize="13" LineBreakMode="WordWrap" FontAutoScalingEnabled="True"
                           Text="2.1.1 Keyboard — all functionality is accessible via the platform's accessibility input methods." />
                    <Label TextColor="#CCCCCC" FontSize="13" LineBreakMode="WordWrap" FontAutoScalingEnabled="True"
                           Text="2.4.2 Page Titled — every page has a meaningful title (Dashboard, Workout Log, Hunter's Guide)." />
                    <Label TextColor="#CCCCCC" FontSize="13" LineBreakMode="WordWrap" FontAutoScalingEnabled="True"
                           Text="3.3.1 Error Identification — validation errors in the workout log clearly describe the problem in plain language." />
                    <Label TextColor="#CCCCCC" FontSize="13" LineBreakMode="WordWrap" FontAutoScalingEnabled="True"
                           Text="3.3.2 Labels or Instructions — all input fields have visible labels and screen reader hints describing expected input." />
                    <Label TextColor="#CCCCCC" FontSize="13" LineBreakMode="WordWrap" FontAutoScalingEnabled="True"
                           Text="Text-to-speech announcements also support users who benefit from audio feedback for rank-ups and quest completions." />
                </VerticalStackLayout>
            </Border>

            <!-- Back Button -->
            <Button Text="Back to Main"
                    BackgroundColor="#3D5AFE" TextColor="White"
                    FontSize="16" CornerRadius="4" HeightRequest="52"
                    Clicked="OnBackClicked"
                    SemanticProperties.Description="Go back to the main dashboard"
                    SemanticProperties.Hint="Returns to the LevelUp dashboard" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
